generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SensorReading {
  id        Int      @id @default(autoincrement())
  sensor    Int
  distance  Float
  angle     Float
  unit      String   @default("cm")
  createdAt DateTime @default(now())

  @@index([sensor, createdAt])
  @@map("sensor_readings")
}

model SensorConfig {
  sensor    Int      @id
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("sensor_config")
}

// Single physical actuator: an LED. Singleton row (id = 1). The ESP32 sets it
// true on detection (<=30cm) and reads it to drive the LED; the dashboard toggle
// is what turns it back off. The trigger logic lives on the device, not here.
model ActuatorConfig {
  id        Int      @id @default(1)
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("actuator_config")
}

// Rotation motor (servo) on/off, persisted in the DB. Singleton (id = 1).
// The ESP32 reads this and only sweeps the servo / advances the angle when
// enabled; when disabled it freezes in place so it resumes from the same angle.
// Defaults to enabled so the radar rotates out of the box.
model MotorConfig {
  id        Int      @id @default(1)
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("motor_config")
}

// Global on/off switch for SMS sending, persisted in the DB. Singleton (id = 1).
// When disabled, the server records nothing and sends nothing (saves credits).
model SmsConfig {
  id        Int      @id @default(1)
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("sms_config")
}

// Audit log of every SMS the server dispatched. Also acts as the throttle
// source-of-truth: a new SMS is only sent if the most recent row is >=30s old
// (so at most 2 SMS/minute). status is 'sent' or 'failed'.
model SmsLog {
  id        Int      @id @default(autoincrement())
  recipient String
  body      String
  sensor    Int?
  distance  Float?
  status    String   @default("sent")
  sid       String?
  error     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("sms_log")
}
