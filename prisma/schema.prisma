generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SensorReading {
  id        Int      @id @default(autoincrement())
  distance  Float
  unit      String   @default("cm")
  createdAt DateTime @default(now())

  @@map("sensor_readings")
}

model BellState {
  id        Int      @id @default(1)
  active    Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("bell_state")
}
