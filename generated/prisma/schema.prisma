generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SensorReading {
  id        Int      @id @default(autoincrement())
  sensor    Int
  distance  Float
  angle     Float
  unit      String   @default("cm")
  createdAt DateTime @default(now())

  @@index([sensor, createdAt])
  @@map("sensor_readings")
}
